{
    "name": "olonjs-monorepo",
    "private": true,
    "type": "module",
    "workspaces": [
        "packages/*",
        "apps/*"
    ],
    "scripts": {
        "dev": "npm run dev -w tenant-alpha",
        "dev2": "npm run dev -w tenant-agritourism",
        "build": "npm run build -w tenant-alpha",
        "build:all": "npm run build --workspaces --if-present",
        "release": "node scripts/release.js",
        "check:templates": "node scripts/check-cli-templates.mjs",
        "dist:dna:all": "npm run dist -w tenant-alpha && npm run dist -w tenant-agritourism",
        "release:enterprise": "node scripts/release-enterprise.js"
    },
    "devDependencies": {
        "@types/file-saver": "^2.0.7",
        "typescript": "^5.7.3"
    },
    "version": "0.0.32"
}
