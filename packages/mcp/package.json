{
  "name": "@olonjs/mcp",
  "version": "1.0.104",
  "description": "Local MCP server bridge for OlonJS Tenant Zero-UI automation via Playwright",
  "private": false,
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "olonjs-mcp": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --clean",
    "dev": "tsup src/cli.ts --format esm --watch",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "playwright": "^1.49.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "@types/node": "^22.10.2"
  }
}
