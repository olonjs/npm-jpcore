{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "olonjs/specs/menu.schema.json",
  "title": "OlonJS MenuConfig",
  "description": "Contract for src/data/config/menu.json. menu.json is the source of truth for menu structures.",
  "type": "object",
  "propertyNames": {
    "type": "string",
    "minLength": 1
  },
  "additionalProperties": {
    "type": "array",
    "items": {
      "$ref": "#/$defs/MenuItem"
    }
  },
  "properties": {
    "main": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/MenuItem"
      }
    }
  },
  "$defs": {
    "MenuItem": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string"
        },
        "href": {
          "type": "string"
        },
        "icon": {
          "type": "string"
        },
        "external": {
          "type": "boolean"
        },
        "isCta": {
          "type": "boolean"
        },
        "children": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MenuItem"
          }
        }
      },
      "required": [
        "label",
        "href"
      ]
    }
  }
}
